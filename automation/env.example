# ── NPA access (required) ─────────────────────────────────────
NPA_USER_ID=123292
NPA_COMPANY_ID=1
NPA_APP_ID=3
NPA_ITS_FROM_PERSOL=Persol Systems Limited
# URLs have working defaults; override only if they change:
# NPA_BDC_BALANCE_URL=https://iml.npa-enterprise.com/NPAAPILIVE/Home/CreateProductBalance
# NPA_OMC_LOADINGS_URL=https://iml.npa-enterprise.com/NewNPA/home/CreateOrdersReport

# ── Report behaviour ──────────────────────────────────────────
REPORT_FETCH_MODE=single          # single = 1-2 API calls; per_bdc = loop all BDC_USER_* creds
REPORT_LOADINGS_DAYS_BACK=1       # loadings report covers this many days ago (1 = yesterday)
OMC_NAME=OILCORP ENERGIA LIMITED  # whose market share fills the loadings card

# ── WhatsApp (Whapi.Cloud) ────────────────────────────────────
WHATSAPP_PROVIDER=whapi
WHAPI_TOKEN=your_whapi_channel_token
WHATSAPP_GROUP_ID=120363xxxxxxxxxxxx@g.us

# ── Only needed if REPORT_FETCH_MODE=per_bdc ──────────────────
# BDC_USER_BOST=...
# BDC_USER_FUELTRADE_LIMITED=...
# (one BDC_USER_* line per BDC, exactly as in your Streamlit app's .env)
